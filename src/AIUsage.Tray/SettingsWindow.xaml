<Window x:Class="AIUsage.Tray.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AIUsage Settings"
        Width="360" Height="480"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">
    <Border Background="{StaticResource WindowBrush}"
            BorderBrush="{StaticResource BorderBrush0}"
            BorderThickness="1"
            CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.35" Color="Black" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="16,14,10,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Settings" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                <Button Grid.Column="1" Style="{StaticResource ChromeButtonStyle}" Click="CloseButton_Click" ToolTip="Close">
                    <Path Data="M1,1 L11,11 M11,1 L1,11" Stroke="{StaticResource TextSecondaryBrush}"
                          StrokeThickness="1.4" Width="12" Height="12" Stretch="Uniform" />
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,0,10,8">
                <StackPanel>
                    <TextBlock Text="PROVIDERS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextTertiaryBrush}"
                               Margin="4,0,0,8" />
                    <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="4">
                        <StackPanel x:Name="ProviderTogglesList" />
                    </Border>

                    <TextBlock Text="ABOUT" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextTertiaryBrush}"
                               Margin="4,18,0,8" />
                    <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="14,10">
                        <StackPanel>
                            <TextBlock x:Name="VersionText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12.5" />
                            <TextBlock Text="A Windows port of OpenUsage." Foreground="{StaticResource TextTertiaryBrush}"
                                       FontSize="11.5" Margin="0,4,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="16,8,16,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Changes apply on next refresh" VerticalAlignment="Center" FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}" />
                <Button Grid.Column="1" Content="Done" Style="{StaticResource PrimaryButtonStyle}" Click="CloseButton_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>
