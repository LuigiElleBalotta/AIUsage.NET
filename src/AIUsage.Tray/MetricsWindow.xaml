<Window x:Class="AIUsage.Tray.MetricsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AIUsage"
        Width="380" Height="560"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        Deactivated="Window_Deactivated">
    <Border Background="{StaticResource WindowBrush}"
            BorderBrush="{StaticResource BorderBrush0}"
            BorderThickness="1"
            CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.35" Color="Black" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Margin="16,14,10,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="AIUsage" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="RefreshChromeButton" Style="{StaticResource ChromeButtonStyle}"
                            Click="RefreshButton_Click" ToolTip="Refresh now">
                        <Path Data="M2,8 A6,6 0 1 1 4,12.2 M2,8 L2,3 M2,8 L6.2,8"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.4" Width="14" Height="14" Stretch="Uniform" />
                    </Button>
                    <Button x:Name="SettingsChromeButton" Style="{StaticResource ChromeButtonStyle}"
                            Click="SettingsButton_Click" ToolTip="Settings">
                        <Path Data="M9,2 L11,2 L11.6,4.4 L13.6,5.5 L15.9,4.6 L17.3,6 L16.4,8.3 L17.5,10.3 L19.9,10.9 L19.9,12.9 L17.5,13.5 L16.4,15.5 L17.3,17.8 L15.9,19.2 L13.6,18.3 L11.6,19.4 L11,21.8 L9,21.8 L8.4,19.4 L6.4,18.3 L4.1,19.2 L2.7,17.8 L3.6,15.5 L2.5,13.5 L0.1,12.9 L0.1,10.9 L2.5,10.3 L3.6,8.3 L2.7,6 L4.1,4.6 L6.4,5.5 L8.4,4.4 Z M10,8.5 A3.4,3.4 0 1 0 10,15.3 A3.4,3.4 0 1 0 10,8.5 Z"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Width="15" Height="15" Stretch="Uniform" />
                    </Button>
                    <Button x:Name="CloseChromeButton" Style="{StaticResource ChromeButtonStyle}"
                            Click="CloseButton_Click" ToolTip="Close">
                        <Path Data="M1,1 L11,11 M11,1 L1,11"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.4" Width="12" Height="12" Stretch="Uniform" />
                    </Button>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,0,10,8">
                <StackPanel x:Name="ProviderList" />
            </ScrollViewer>

            <!-- Footer -->
            <Grid Grid.Row="2" Margin="16,8,16,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FooterStatusText" Text="" VerticalAlignment="Center" FontSize="11.5"
                           Foreground="{StaticResource TextTertiaryBrush}" />
                <Button Grid.Column="1" Content="Refresh Now" Style="{StaticResource FlatButtonStyle}"
                        Click="RefreshButton_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>
