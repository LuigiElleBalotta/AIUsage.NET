<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <RootNamespace>AIUsage.Cli</RootNamespace>
    <AssemblyName>aiusage</AssemblyName>
    <InvariantGlobalization>false</InvariantGlobalization>
    <ApplicationIcon Condition="Exists('..\AIUsage.Tray\Resources\aiusage.ico')">..\AIUsage.Tray\Resources\aiusage.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\AIUsage.Core\AIUsage.Core.csproj" />
  </ItemGroup>

</Project>
